{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Electron: Run",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron",
      "runtimeArgs": [".", "--dev"],
      "cwd": "${workspaceFolder}",
      "env": { "ELECTRON_ENABLE_LOGGING": "1" },
      "sourceMaps": true,
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Electron: Debug main process",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron",
      "runtimeArgs": [".", "--dev", "--remote-debugging-port=9229"],
      "cwd": "${workspaceFolder}",
      "env": { "ELECTRON_ENABLE_LOGGING": "1" },
      "sourceMaps": true,
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "presentation": {
        "group": "debug",
        "order": 1
      }
    }
  ]
}
